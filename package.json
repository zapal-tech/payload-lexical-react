{
  "name": "@zapal/payload-lexical-react",
  "version": "1.9.0",
  "private": false,
  "description": "Payload CMS rich text Lexical editor to React JSX renderer",
  "keywords": [
    "payload",
    "cms",
    "richtext",
    "lexical",
    "render",
    "ssr",
    "react",
    "html",
    "zapal",
    "zapal-tech"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zapal-tech/payload-lexical-react.git"
  },
  "license": "MIT",
  "author": {
    "name": "Zapal",
    "email": "hello@zapal.tech",
    "url": "https://www.zapal.tech"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/payload-lexical-react.es.js",
      "require": "./dist/dist/payload-lexical-react.umd.js"
    }
  },
  "main": "dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "check-updates": "pnpm dlx taze major",
    "check-updates:minor": "pnpm dlx taze minor",
    "dev": "vite",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,json5,html,gql,graphql,md,css,scss}\"",
    "lint": "eslint src",
    "lint:types": "tsc",
    "prepare": "node scripts/prepare",
    "prepublishOnly": "pnpm build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@lexical/list": "^0.28.0",
    "@lexical/rich-text": "^0.28.0",
    "@payloadcms/richtext-lexical": "^3.81.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^3.2.4",
    "@zapal/dx": "^1.4.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lexical": "^0.41.0",
    "lint-staged": "^15.5.2",
    "payload": "^3.81.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^2.5.22",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "lexical": "^0.41.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
